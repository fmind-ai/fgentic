import logging
from typing import Dict

from apps.activitypub-agent-gateway.internal.apgateway.agents import Agents
from apps.activitypub-agent-gateway.internal.apgateway.retention_policy import RetentionPolicy

logger = logging.getLogger(__name__)

class Store:
    def __init__(self, agents: Agents, retention_policy: RetentionPolicy):
        self.agents = agents
        self.retention_policy = retention_policy

    def delete_session(self, context_id: str) -> None:
        """
        Delete a session from the kagent.
        """
        try:
            self.agents.forget(context_id)
        except Exception as e:
            logger.error(f"Error deleting session: {e}")

    def reset_context_id(self, context_id: str) -> None:
        """
        Reset the stored contextId.
        """
        try:
            self.agents.reset_context_id(context_id)
        except Exception as e:
            logger.error(f"Error resetting contextId: {e}")

    def get_sessions(self) -> Dict[str, str]:
        """
        Get all sessions stored in the kagent.
        """
        try:
            return self.agents.get_sessions()
        except Exception as e:
            logger.error(f"Error getting sessions: {e}")
            return {}