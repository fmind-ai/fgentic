# TEMPLATE — the P-256 key that anchors the ActivityPub agent gateway's FEP-c390 cross-transport
# identity (issue #218): each actor binds to this key's did:key and its A2A AgentCard publishes the
# matching JWK, so a verifier confirms both federation faces share one sovereign key. The key — not
# the hostname — is the anchor, so the binding survives a domain move. The gateway is an opt-in,
# additive federation transport not yet in the reconciled DAG, so this key is generated by hand when
# the gateway is enabled — NOT by scripts/gen-secrets.sh.
#
# Generate a fresh P-256 PKCS#8 PEM key, then encrypt in place (never commit the plaintext):
#   openssl genpkey -algorithm EC -pkeyopt ec_paramgen_curve:P-256 -out p256.pem
#   # paste p256.pem into stringData.p256.pem below, then:
#   sops --encrypt --in-place clusters/<env>/secrets/activitypub-agent-gateway-identity-key.sops.yaml
#
# Rotate deliberately: a new key changes the did:key (the identity anchor), so remote verifiers that
# pinned the old did must re-pin. Keep the private key in-cluster only.
apiVersion: v1
kind: Secret
metadata:
  name: activitypub-agent-gateway-identity-key
  namespace: activitypub
type: Opaque
stringData:
  p256.pem: |
    -----BEGIN PRIVATE KEY-----
    REPLACE_WITH_P256_PKCS8_PEM
    -----END PRIVATE KEY-----
