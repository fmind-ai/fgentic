# TEMPLATE — Anthropic API key, held only by agentgateway.
# Store the raw key: agentgateway moves its generated Bearer credential to Anthropic's x-api-key.
apiVersion: v1
kind: Secret
metadata:
  name: anthropic-secret
  namespace: agentgateway-system
type: Opaque
stringData:
  Authorization: REPLACE_WITH_ANTHROPIC_API_KEY
