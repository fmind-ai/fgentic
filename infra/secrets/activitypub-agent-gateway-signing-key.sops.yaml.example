# TEMPLATE — the ActivityPub agent gateway's signing keys. ed25519.pem attaches FEP-8b32 object
# integrity proofs (eddsa-jcs-2022) to outbound replies and publishes each actor's assertionMethod
# Multikey (issue #212). rsa.pem is the separate hop-by-hop transport key for outbound RFC 9421 /
# Cavage HTTP signatures published as each actor's `#main-key` (issue #476) — MANDATORY whenever the
# groups or status-feed outbound delivery is enabled (the deploy enables both), so the gateway pod
# fails to start without it. Both live in this one Secret; the demo profile generates the cluster-only
# equivalents in scripts/lib/demo-secrets.sh, NOT via scripts/gen-secrets.sh.
#
# Generate fresh PKCS#8 PEM keys, then encrypt in place (never commit the plaintext):
#   openssl genpkey -algorithm ed25519 -out ed25519.pem
#   openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048 -out rsa.pem   # >= 2048 bits
#   # paste each PEM into stringData below, then:
#   sops --encrypt --in-place clusters/<env>/secrets/activitypub-agent-gateway-signing-key.sops.yaml
#
# Rotate by generating a new key and republishing the actor documents (verificationMethod fragment
# is unchanged; the published publicKeyMultibase / #main-key changes). Keep the private keys
# in-cluster only.
apiVersion: v1
kind: Secret
metadata:
  name: activitypub-agent-gateway-signing-key
  namespace: activitypub
type: Opaque
stringData:
  ed25519.pem: |
    -----BEGIN PRIVATE KEY-----
    REPLACE_WITH_ED25519_PKCS8_PEM
    -----END PRIVATE KEY-----
  rsa.pem: |
    -----BEGIN PRIVATE KEY-----
    REPLACE_WITH_RSA_2048_PKCS8_PEM
    -----END PRIVATE KEY-----
