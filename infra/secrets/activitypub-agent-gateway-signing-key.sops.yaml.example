# TEMPLATE — the Ed25519 key the ActivityPub agent gateway uses to attach FEP-8b32 object integrity
# proofs (eddsa-jcs-2022) to outbound replies and to publish each actor's assertionMethod Multikey
# (issue #212). The gateway is an opt-in, additive federation transport not yet in the reconciled DAG,
# so this key is generated by hand when the gateway is enabled — NOT by scripts/gen-secrets.sh.
#
# Generate a fresh PKCS#8 PEM key, then encrypt in place (never commit the plaintext):
#   openssl genpkey -algorithm ed25519 -out ed25519.pem
#   # paste ed25519.pem into stringData.ed25519.pem below, then:
#   sops --encrypt --in-place clusters/<env>/secrets/activitypub-agent-gateway-signing-key.sops.yaml
#
# Rotate by generating a new key and republishing the actor documents (verificationMethod fragment
# is unchanged; the published publicKeyMultibase changes). Keep the private key in-cluster only.
apiVersion: v1
kind: Secret
metadata:
  name: activitypub-agent-gateway-signing-key
  namespace: activitypub
type: Opaque
stringData:
  ed25519.pem: |
    -----BEGIN PRIVATE KEY-----
    REPLACE_WITH_ED25519_PKCS8_PEM
    -----END PRIVATE KEY-----
