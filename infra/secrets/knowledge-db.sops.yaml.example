# TEMPLATE — `scripts/gen-secrets.sh` generates independent owner and retrieval credentials and
# encrypts them immediately. CNPG reads both copies in `postgres`; the future retrieval workload
# reads the identical retrieval credential from `knowledge`. The owner credential is never copied
# into a workload namespace.
apiVersion: v1
kind: Secret
metadata:
  name: pg-knowledge-owner
  namespace: postgres
type: kubernetes.io/basic-auth
stringData:
  username: knowledge_owner
  password: REPLACE_WITH_PG_KNOWLEDGE_OWNER_PASSWORD
---
apiVersion: v1
kind: Secret
metadata:
  name: pg-knowledge-retrieval
  namespace: postgres
type: kubernetes.io/basic-auth
stringData:
  username: knowledge_retrieval
  password: REPLACE_WITH_PG_KNOWLEDGE_RETRIEVAL_PASSWORD
---
apiVersion: v1
kind: Secret
metadata:
  name: pg-knowledge-retrieval
  namespace: knowledge
type: kubernetes.io/basic-auth
stringData:
  username: knowledge_retrieval
  password: REPLACE_WITH_PG_KNOWLEDGE_RETRIEVAL_PASSWORD
