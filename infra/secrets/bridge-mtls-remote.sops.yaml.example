# TEMPLATE (#244) — client-certificate material the bridge presents to ONE pinned remote A2A peer
# for A2A v1.0 mutual TLS. Copy per remote mapping, replace each value with the PEM issued to (or
# for) this bridge by the partner, encrypt with SOPS, and commit only the encrypted file. Mount it
# via the chart's extraVolumes/extraVolumeMounts at the paths the mapping's `mtls:` block references
# (docs/bridge.md §6). NEVER commit plaintext key material; the values below are placeholders.
apiVersion: v1
kind: Secret
metadata:
  name: bridge-mtls-partner-reviewer
  namespace: bridge
type: Opaque
stringData:
  # Full PEM bundles (BEGIN/END CERTIFICATE and BEGIN/END PRIVATE KEY blocks) go here.
  tls.crt: REPLACE_WITH_BRIDGE_CLIENT_CERTIFICATE_PEM
  tls.key: REPLACE_WITH_BRIDGE_CLIENT_PRIVATE_KEY_PEM
  # Optional: pin the roots that verify the partner's SERVER certificate. Omit to use system roots.
  ca.crt: REPLACE_WITH_PARTNER_SERVER_CA_PEM
