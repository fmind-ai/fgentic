# TEMPLATE — the appservice registration, shared by the bridge AND the homeserver. The SAME
# encrypted content is needed in TWO namespaces (bridge: the appservice; matrix: Synapse loads it),
# so create the Secret in both. Generate the tokens with `go run ./cmd/bridge -generate-registration`
# (in apps/matrix-a2a-bridge) or `openssl rand -hex 32`. Store ONLY as SOPS ciphertext.
apiVersion: v1
kind: Secret
metadata:
  name: matrix-a2a-bridge-registration
  namespace: bridge
type: Opaque
stringData:
  registration.yaml: |
    id: matrix-a2a-bridge
    url: http://matrix-a2a-bridge.bridge.svc.cluster.local:29331
    as_token: REPLACE_WITH_64_HEX_CHARS_AS_TOKEN
    hs_token: REPLACE_WITH_64_HEX_CHARS_HS_TOKEN
    sender_localpart: a2a-bridge
    rate_limited: false
    namespaces:
      users:
        - regex: '@a2a-bridge:ai\.fmind\.dev'
          exclusive: true
        - regex: '@agent-.*:ai\.fmind\.dev'
          exclusive: true
---
apiVersion: v1
kind: Secret
metadata:
  name: matrix-a2a-bridge-registration
  namespace: matrix
type: Opaque
stringData:
  registration.yaml: |
    id: matrix-a2a-bridge
    url: http://matrix-a2a-bridge.bridge.svc.cluster.local:29331
    as_token: REPLACE_WITH_64_HEX_CHARS_AS_TOKEN
    hs_token: REPLACE_WITH_64_HEX_CHARS_HS_TOKEN
    sender_localpart: a2a-bridge
    rate_limited: false
    namespaces:
      users:
        - regex: '@a2a-bridge:ai\.fmind\.dev'
          exclusive: true
        - regex: '@agent-.*:ai\.fmind\.dev'
          exclusive: true
