# TEMPLATE — generate this coherent database + gateway workload credential set with
# `FGENTIC_SECRET_SET=knowledge-ingestion scripts/gen-secrets.sh <server_name> <env>`.
# The schema-owner and every model/provider credential remain outside the ingestion workload.
apiVersion: v1
kind: Secret
metadata:
  name: pg-knowledge-ingestion
  namespace: postgres
type: kubernetes.io/basic-auth
stringData:
  username: knowledge_ingestion
  password: REPLACE_WITH_PG_KNOWLEDGE_INGESTION_PASSWORD
---
apiVersion: v1
kind: Secret
metadata:
  name: pg-knowledge-ingestion
  namespace: knowledge
type: kubernetes.io/basic-auth
stringData:
  username: knowledge_ingestion
  password: REPLACE_WITH_PG_KNOWLEDGE_INGESTION_PASSWORD
---
apiVersion: v1
kind: Secret
metadata:
  name: knowledge-ingestion-callers
  namespace: agentgateway-system
type: Opaque
stringData:
  knowledge-ingestion: |
    {
      "key": "REPLACE_WITH_KNOWLEDGE_INGESTION_WORKLOAD_CREDENTIAL",
      "metadata": {
        "workload": "knowledge-ingestion"
      }
    }
---
apiVersion: v1
kind: Secret
metadata:
  name: knowledge-ingestion-credential
  namespace: knowledge
type: Opaque
stringData:
  authorization: Bearer REPLACE_WITH_KNOWLEDGE_INGESTION_WORKLOAD_CREDENTIAL
