# TEMPLATE — the model provider credential, held ONLY by agentgateway (the single chokepoint).
# agentgateway's default secret resolver reads the data key literally named `Authorization`.
# For the default Anthropic backend (infra/agentgateway/llm-backend.yaml), this is the API key.
apiVersion: v1
kind: Secret
metadata:
  name: model-secret
  namespace: agentgateway-system
type: Opaque
stringData:
  Authorization: REPLACE_WITH_MODEL_PROVIDER_API_KEY
