# TEMPLATE — OpenAI API key, held only by agentgateway.
# The pinned controller resolves the literal `Authorization` data key and adds `Bearer ` upstream.
apiVersion: v1
kind: Secret
metadata:
  name: openai-secret
  namespace: agentgateway-system
type: Opaque
stringData:
  Authorization: REPLACE_WITH_OPENAI_API_KEY
