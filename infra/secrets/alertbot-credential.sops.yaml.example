# TEMPLATE — provisioning outputs for the opt-in sovereign alert delivery (issue #456). Create the
# real per-cluster copy under clusters/<env>/secrets/ only when alert_delivery is enabled: provision
# a dedicated @alertbot user with a long-lived Matrix ACCESS TOKEN (not a password — no MAS login
# needed), invite it to a dedicated private ops room, and fill in the values below then SOPS-encrypt.
#
# INVARIANT (D7/D8): @alertbot must NEVER be added to any agent's allowedSenders and must stay
# outside the bridge's @a2a-bridge / @agent-.* exclusive namespace, so an alert can never invoke an
# agent. scripts/test-alert-delivery.sh asserts that non-membership.
apiVersion: v1
kind: Secret
metadata:
  name: alertbot-credential
  namespace: alert-delivery
type: Opaque
stringData:
  ALERTBOT_ACCESS_TOKEN: REPLACE_WITH_ALERTBOT_MATRIX_ACCESS_TOKEN
  ALERTBOT_OPS_ROOM_ID: REPLACE_WITH_OPS_ROOM_ID
