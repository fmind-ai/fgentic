# TEMPLATE — `scripts/gen-secrets.sh` generates this pair and encrypts it immediately. CNPG
# manages the role from `postgres`, while the chart reads it from `keycloak`; keep both copies
# identical and restart Keycloak after rotating them.
apiVersion: v1
kind: Secret
metadata:
  name: pg-keycloak
  namespace: postgres
type: kubernetes.io/basic-auth
stringData:
  username: keycloak
  password: REPLACE_WITH_PG_KEYCLOAK_PASSWORD
---
apiVersion: v1
kind: Secret
metadata:
  name: pg-keycloak
  namespace: keycloak
type: kubernetes.io/basic-auth
stringData:
  username: keycloak
  password: REPLACE_WITH_PG_KEYCLOAK_PASSWORD
