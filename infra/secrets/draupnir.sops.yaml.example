# TEMPLATE — optional Draupnir v3.1.0 moderation credentials. Generate real ciphertext with:
#   FGENTIC_SECRET_SET=moderation scripts/gen-secrets.sh <server_name> <local|gcp>
# then replace the placeholder access token with the real one obtained by logging the bot account
# in (provision @moderation-bot via a MAS registration token, log in, copy its access token) — see
# docs/moderation.md. Draupnir bot mode has NO database, so there is no CNPG role/Secret here.
apiVersion: v1
kind: Secret
metadata:
  name: draupnir
  namespace: moderation
type: Opaque
stringData:
  # The Matrix access token of the @moderation-bot account. Passed via --access-token-path.
  access-token: REPLACE_WITH_DRAUPNIR_ACCESS_TOKEN
---
# Only needed when the optional infra/moderation/antispam component is composed. It carries the
# Synapse-side synapse-http-antispam module registration; `authorization` must equal Draupnir's
# web.synapseHTTPAntispam.authorization. Keep this file out of git in real clusters (SOPS only).
apiVersion: v1
kind: Secret
metadata:
  name: draupnir-antispam-module
  namespace: matrix
type: Opaque
stringData:
  module.yaml: |
    modules:
      - module: synapse_http_antispam.HTTPAntispam
        config:
          base_url: http://draupnir.moderation.svc.cluster.local:8082
          authorization: REPLACE_WITH_ANTISPAM_AUTHORIZATION
          do_ping: true
          enabled_callbacks:
            - user_may_invite
            - user_may_join_room
            - check_event_for_spam
          fail_open:
            user_may_invite: true
            user_may_join_room: true
            check_event_for_spam: true
