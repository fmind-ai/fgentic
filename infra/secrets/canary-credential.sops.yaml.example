# TEMPLATE — provisioning outputs for the opt-in synthetic delegation canary (issue #454). Create
# the real per-cluster copy under clusters/<env>/secrets/ only when synthetic_canary is enabled:
# provision a dedicated, allowlisted @canary user (MAS Admin API, like the demo alice), a dedicated
# unencrypted canary room the target ghost is invited to, add the canary MXID to that ghost's
# `allowedSenders` in the agents.yaml Secret, then fill in the values below and SOPS-encrypt.
# The canary is an ordinary allowlisted sender on the normal admission/rate path — no bypass.
apiVersion: v1
kind: Secret
metadata:
  name: canary-credential
  namespace: canary
type: Opaque
stringData:
  CANARY_USER: canary
  CANARY_PASSWORD: REPLACE_WITH_CANARY_USER_PASSWORD
  CANARY_ROOM_ID: REPLACE_WITH_CANARY_ROOM_ID
