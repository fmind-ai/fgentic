# TEMPLATE — kagent's Postgres connection URL (its own `kagent` database, TLS required) and a
# placeholder OpenAI key. kagent egresses models THROUGH agentgateway, so this key is a dummy the
# gateway ignores for ambient auth; put a real dev key here only if agentgateway is configured to
# require one from callers.
apiVersion: v1
kind: Secret
metadata:
  name: kagent-db
  namespace: kagent
type: Opaque
stringData:
  url: postgresql://kagent:REPLACE_ME@platform-pg-rw.postgres.svc.cluster.local:5432/kagent?sslmode=require
---
apiVersion: v1
kind: Secret
metadata:
  name: kagent-model-auth
  namespace: kagent
type: Opaque
stringData:
  OPENAI_API_KEY: sk-not-used-agentgateway-holds-the-real-key
