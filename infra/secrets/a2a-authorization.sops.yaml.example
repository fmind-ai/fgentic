# TEMPLATE — `scripts/gen-secrets.sh` generates one random credential into both Secrets and
# encrypts the file immediately. The server-side JSON metadata is what the CEL policy authorizes.
apiVersion: v1
kind: Secret
metadata:
  name: a2a-bridge-callers
  namespace: agentgateway-system
type: Opaque
stringData:
  matrix-a2a-bridge: |
    {
      "key": "REPLACE_WITH_A2A_WORKLOAD_CREDENTIAL",
      "metadata": {
        "workload": "matrix-a2a-bridge"
      }
    }
---
apiVersion: v1
kind: Secret
metadata:
  name: a2a-bridge-credential
  namespace: bridge
type: Opaque
stringData:
  token: REPLACE_WITH_A2A_WORKLOAD_CREDENTIAL
