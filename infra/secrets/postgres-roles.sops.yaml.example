# TEMPLATE — copy to postgres-roles.sops.yaml, set real passwords, then `sops -e -i` it.
# CloudNativePG managed-role password Secrets: type basic-auth with username + password keys.
# One per tenant role declared in infra/postgres/cluster.yaml.
apiVersion: v1
kind: Secret
metadata:
  name: pg-synapse
  namespace: postgres
type: kubernetes.io/basic-auth
stringData:
  username: synapse
  password: REPLACE_ME
---
apiVersion: v1
kind: Secret
metadata:
  name: pg-mas
  namespace: postgres
type: kubernetes.io/basic-auth
stringData:
  username: mas
  password: REPLACE_ME
---
apiVersion: v1
kind: Secret
metadata:
  name: pg-bridge
  namespace: postgres
type: kubernetes.io/basic-auth
stringData:
  username: bridge
  password: REPLACE_ME
---
apiVersion: v1
kind: Secret
metadata:
  name: pg-kagent
  namespace: postgres
type: kubernetes.io/basic-auth
stringData:
  username: kagent
  password: REPLACE_ME
