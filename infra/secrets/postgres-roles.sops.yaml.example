# TEMPLATE — copy to postgres-roles.sops.yaml, set real passwords, then `sops -e -i` it.
# CloudNativePG managed-role password Secrets: type basic-auth with username + password keys.
# Core platform roles live here; the optional IdP's namespace-paired role is documented in
# keycloak-db.sops.yaml.example so an existing cluster can add it without rotating these roles.
apiVersion: v1
kind: Secret
metadata:
  name: pg-synapse
  namespace: postgres
type: kubernetes.io/basic-auth
stringData:
  username: synapse
  password: REPLACE_ME
---
apiVersion: v1
kind: Secret
metadata:
  name: pg-mas
  namespace: postgres
type: kubernetes.io/basic-auth
stringData:
  username: mas
  password: REPLACE_ME
---
apiVersion: v1
kind: Secret
metadata:
  name: pg-bridge
  namespace: postgres
type: kubernetes.io/basic-auth
stringData:
  username: bridge
  password: REPLACE_ME
---
apiVersion: v1
kind: Secret
metadata:
  name: pg-kagent
  namespace: postgres
type: kubernetes.io/basic-auth
stringData:
  username: kagent
  password: REPLACE_ME
