# TEMPLATE — copy to matrix-a2a-bridge-db.sops.yaml, fill the real password, then encrypt:
#   sops -e -i matrix-a2a-bridge-db.sops.yaml
# The URL is the bridge's Postgres connection string (role/database `bridge` in the shared
# CloudNativePG cluster — ADR 0007). It backs the mautrix StateStore + the bridge's context
# and event-dedup tables (SPEC §5). The chart mounts it as env DATABASE_URL.
apiVersion: v1
kind: Secret
metadata:
  name: matrix-a2a-bridge-db
  namespace: bridge
type: Opaque
stringData:
  url: postgres://bridge:REPLACE_WITH_PG_BRIDGE_PASSWORD@platform-pg-rw.postgres.svc.cluster.local:5432/bridge?sslmode=require
