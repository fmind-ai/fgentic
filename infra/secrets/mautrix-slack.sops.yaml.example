# TEMPLATE — optional mautrix-slack v0.2606.0 credentials. Generate real ciphertext with:
#   FGENTIC_SECRET_SET=slack scripts/gen-secrets.sh <server_name> <local|gcp>
# Slack xoxb/xapp credentials are entered through the bridge's Matrix login flow and stored in
# its scoped database; they are intentionally not deployment Secrets.
apiVersion: v1
kind: Secret
metadata:
  name: pg-slackbridge
  namespace: postgres
type: kubernetes.io/basic-auth
stringData:
  username: slackbridge
  password: REPLACE_WITH_PG_SLACKBRIDGE_PASSWORD
---
apiVersion: v1
kind: Secret
metadata:
  name: mautrix-slack
  namespace: bridges
type: Opaque
stringData:
  database-uri: postgres://slackbridge:REPLACE_WITH_PG_SLACKBRIDGE_PASSWORD@platform-pg-rw.postgres.svc.cluster.local:5432/slackbridge?sslmode=require
  as-token: REPLACE_WITH_AS_TOKEN
  hs-token: REPLACE_WITH_HS_TOKEN
---
apiVersion: v1
kind: Secret
metadata:
  name: mautrix-slack-registration
  namespace: matrix
type: Opaque
stringData:
  registration.yaml: |
    id: slack
    url: http://mautrix-slack.bridges.svc.cluster.local:29335
    as_token: REPLACE_WITH_AS_TOKEN
    hs_token: REPLACE_WITH_HS_TOKEN
    # bridge-v2 deliberately generates a random 32-character sender localpart distinct from the
    # configured bot username. The bot and ghost namespaces below remain stable.
    sender_localpart: REPLACE_WITH_RANDOM_32_CHARACTER_LOCALPART
    rate_limited: false
    namespaces:
      users:
        - regex: ^@slackbot:REPLACE_WITH_ESCAPED_SERVER_NAME$
          exclusive: true
        - regex: ^@slack_.*:REPLACE_WITH_ESCAPED_SERVER_NAME$
          exclusive: true
    de.sorunome.msc2409.push_ephemeral: true
    receive_ephemeral: true
