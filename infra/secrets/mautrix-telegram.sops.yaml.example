# TEMPLATE — optional mautrix-telegram v0.2606.0 credentials. Generate real ciphertext with:
#   TELEGRAM_API_ID=<id> TELEGRAM_API_HASH=<hash> FGENTIC_SECRET_SET=telegram \
#     scripts/gen-secrets.sh <server_name> <local|gcp>
# The API credentials come from https://my.telegram.org/apps and are required only for this
# explicit secret set. User login happens through the bridge's Matrix management room.
apiVersion: v1
kind: Secret
metadata:
  name: pg-telegrambridge
  namespace: postgres
type: kubernetes.io/basic-auth
stringData:
  username: telegrambridge
  password: REPLACE_WITH_PG_TELEGRAMBRIDGE_PASSWORD
---
apiVersion: v1
kind: Secret
metadata:
  name: mautrix-telegram
  namespace: bridges
type: Opaque
stringData:
  database-uri: postgres://telegrambridge:REPLACE_WITH_PG_TELEGRAMBRIDGE_PASSWORD@platform-pg-rw.postgres.svc.cluster.local:5432/telegrambridge?sslmode=require
  api-id: REPLACE_WITH_TELEGRAM_API_ID
  api-hash: REPLACE_WITH_TELEGRAM_API_HASH
  as-token: REPLACE_WITH_AS_TOKEN
  hs-token: REPLACE_WITH_HS_TOKEN
---
apiVersion: v1
kind: Secret
metadata:
  name: mautrix-telegram-registration
  namespace: matrix
type: Opaque
stringData:
  registration.yaml: |
    id: telegram
    url: http://mautrix-telegram.bridges.svc.cluster.local:29317
    as_token: REPLACE_WITH_AS_TOKEN
    hs_token: REPLACE_WITH_HS_TOKEN
    # bridge-v2 deliberately generates a random 32-character sender localpart distinct from the
    # configured bot username. Rotation preserves it as the appservice's stable identity.
    sender_localpart: REPLACE_WITH_RANDOM_32_CHARACTER_LOCALPART
    rate_limited: false
    namespaces:
      users:
        - regex: ^@telegrambot:REPLACE_WITH_ESCAPED_SERVER_NAME$
          exclusive: true
        - regex: ^@telegram_.*:REPLACE_WITH_ESCAPED_SERVER_NAME$
          exclusive: true
    de.sorunome.msc2409.push_ephemeral: true
    receive_ephemeral: true
