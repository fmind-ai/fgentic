# Example only — generate per-cluster ciphertext with scripts/gen-secrets.sh. Never use this key.
apiVersion: v1
kind: Secret
metadata:
  name: mcp-agent-callers
  namespace: agentgateway-system
type: Opaque
stringData:
  platform-helper: |
    {
      "key": "replace-with-random-credential",
      "metadata": {
        "agent": "platform-helper"
      }
    }
---
apiVersion: v1
kind: Secret
metadata:
  name: platform-helper-mcp-credential
  namespace: kagent
type: Opaque
stringData:
  authorization: Bearer replace-with-random-credential
