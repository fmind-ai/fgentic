# TEMPLATE — Azure OpenAI API key, held only by agentgateway.
# The Secret key remains `Authorization`; the profile injects its raw value into `api-key` upstream.
apiVersion: v1
kind: Secret
metadata:
  name: azure-openai-secret
  namespace: agentgateway-system
type: Opaque
stringData:
  Authorization: REPLACE_WITH_AZURE_OPENAI_API_KEY
