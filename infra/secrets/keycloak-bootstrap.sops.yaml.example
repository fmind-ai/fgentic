# TEMPLATE — one-time realm bootstrap credentials. Keycloak skips startup import after the realm
# exists, so the generator deliberately preserves an existing bootstrap file even with --force.
# Rotate live admin/client/user credentials through Keycloak's Admin API, then update this
# encrypted bootstrap source deliberately if fresh-database recovery should use the new values.
apiVersion: v1
kind: Secret
metadata:
  name: keycloak-credentials
  namespace: keycloak
type: Opaque
stringData:
  KC_BOOTSTRAP_ADMIN_USERNAME: admin
  KC_BOOTSTRAP_ADMIN_PASSWORD: REPLACE_WITH_ADMIN_PASSWORD
  FGENTIC_CLIENT_SECRET: REPLACE_WITH_OIDC_CLIENT_SECRET
  FGENTIC_ALICE_PASSWORD: REPLACE_WITH_ALICE_PASSWORD
  FGENTIC_BOB_PASSWORD: REPLACE_WITH_BOB_PASSWORD
---
# MAS consumes the same immutable client credential through ESS's supported `additional.configSecret`
# path. Keep both Secrets in this bootstrap-only file so they cannot drift during `--force` rotation.
apiVersion: v1
kind: Secret
metadata:
  name: mas-upstream-oidc
  namespace: matrix
type: Opaque
stringData:
  provider.yaml: |
    upstream_oauth2:
      providers:
        - id: 01H8PKNWKKRPCBW4YGH1RWV279
          issuer: https://id.REPLACE_WITH_SERVER_NAME/realms/fgentic
          human_name: Fgentic
          client_id: fgentic
          client_secret: REPLACE_WITH_OIDC_CLIENT_SECRET
          token_endpoint_auth_method: client_secret_basic
          scope: openid fgentic-groups
          # OIDC backchannel logout (issue #278): an explicit Keycloak user/session logout POSTs a logout
          # token to MAS at /upstream/backchannel-logout/<this id>, and MAS terminates every session
          # started by that upstream OIDC session (browser + client). Session hygiene / defense in depth —
          # NOT the IdP-disable trigger (that is #153). Keycloak requires a session id in the token.
          on_backchannel_logout: logout_all
          claims_imports:
            skip_confirmation: true
            localpart:
              action: require
              template: "{{ user.matrix_localpart }}"
              on_conflict: fail
            displayname:
              action: force
              template: "{{ user.name }}"
            email:
              action: force
              template: "{{ user.email }}"
